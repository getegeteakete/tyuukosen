# ============================================
# Supabase（データベース・認証・ストレージ）
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...     # サーバー専用・絶対公開不可

# ============================================
# AI（オーケストレーターと各エージェント）
# ============================================
ANTHROPIC_API_KEY=sk-ant-...           # 司令塔・記事生成・営業文
OPENAI_API_KEY=sk-...                  # 画像解析・埋め込みで利用

# ============================================
# UnivaPay（サブスク・EC決済）
# ============================================
NEXT_PUBLIC_UNIVAPAY_APP_ID=
UNIVAPAY_SECRET_TOKEN=
UNIVAPAY_WEBHOOK_SECRET=

# ============================================
# メール送信（営業メール・契約通知）
# ============================================
RESEND_API_KEY=re_...
MAIL_FROM="中古船マーケット <noreply@example.com>"

# ============================================
# SNS自動投稿
# ============================================
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# ============================================
# Vercel Cron 認証
# ============================================
CRON_SECRET=ランダム文字列（ヘッダー認証用）

# ============================================
# サイト
# ============================================
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
NEXT_PUBLIC_SITE_NAME=中古船マーケット
